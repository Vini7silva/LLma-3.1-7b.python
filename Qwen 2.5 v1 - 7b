# ================== VOZ OFFLINE (igual script original) ==================
voice = None
try:
    for arquivo in os.listdir(BASE_DIR):
        if arquivo.startswith("pt_BR-faber"):
            caminho_completo = os.path.join(BASE_DIR, arquivo)
            try:
                voice = PiperVoice.load(caminho_completo)
                if voice is not None:
                    break
            except Exception:
